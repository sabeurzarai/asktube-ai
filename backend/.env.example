YOUTUBE_API_KEY=
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Embedding provider ────────────────────────────────────────────────────────
# "openai" (default) or "local". Local = free HuggingFace CPU model.
# REQUIRES the optional extras: pip install -r requirements-local-embeddings.txt
#   (or uncomment the RUN line in backend/Dockerfile). Adds ~0.5–2 GB (torch).
# ⚠ Changing providers changes vector dims — wipe ChromaDB + re-ingest afterward.
EMBEDDING_PROVIDER=openai
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Chat model provider ───────────────────────────────────────────────────────
# "openai" (default) or "nvidia". NVIDIA mode replaces CHAT generation only.
# OPENAI_API_KEY is still REQUIRED for Whisper (and embeddings unless EMBEDDING_PROVIDER=local).
LLM_PROVIDER=openai
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=moonshotai/kimi-k2.6
NVIDIA_TOOL_CALLING=true
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_SEGMENTS=1
AUDIO_CACHE_DIR=data/audio_cache

# Optional: residential proxy for youtube-transcript-api on cloud hosts.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Optional: exact proxy URL from Webshare's Proxy Integration curl snippet.
# If set, this takes priority over username/password/location-based construction.
WEBSHARE_PROXY_URL=
WEBSHARE_PROXY_LOCATIONS=
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION_NAME=asktube_videos
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=AskTube-AI
LANGSMITH_EVAL_PROJECT=AskTube-AI-Evals
LANGSMITH_LATENCY_BUDGET_MS=8000
HALLUCINATION_RISK_THRESHOLD=0.35
RAG_EVALUATOR_MODE=heuristic
ANALYTICS_ENABLED=true
PROMETHEUS_ENABLED=true
# Local/EC2 default. For production PostgreSQL use:
# postgresql+asyncpg://USER:PASSWORD@HOST:5432/asktube_analytics
ANALYTICS_DATABASE_URL=sqlite+aiosqlite:///./data/analytics.db
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=AskTube-AI
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]
