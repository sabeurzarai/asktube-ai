# ──────────────────────────────────────────────────────────────────────────────
# AskTube AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Keys (required) ───────────────────────────────────────────────────────
YOUTUBE_API_KEY=              # Google Cloud Console → YouTube Data API v3
OPENAI_API_KEY=               # platform.openai.com/api-keys

# ── Frontend (required in production) ────────────────────────────────────────
# URL of the deployed backend — used by the Next.js build (baked at build time)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the FastAPI backend.
# Add your deployed frontend URL here (e.g. https://asktube.onrender.com).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI Models ─────────────────────────────────────────────────────────────────
WHISPER_MODEL=whisper-1
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_MAX_CHARS=1200
CHUNK_OVERLAP_SEGMENTS=1

# ── Audio Cache ───────────────────────────────────────────────────────────────
AUDIO_CACHE_DIR=data/audio_cache

# ── YouTube Transcript Proxy (optional for EC2/cloud deployment) ───────────────
# YouTube often blocks transcript requests from AWS/GCP/Azure datacenter IPs.
# Add Webshare residential proxy credentials when deploying on EC2.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=
# Optional comma-separated country codes, e.g. US,DE,NL
WEBSHARE_PROXY_LOCATIONS=

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Local development (embedded, no server needed):
CHROMA_USE_HTTP=false
CHROMA_PERSIST_DIR=./chroma_data

# Docker / production (HTTP client pointing to chromadb service):
# CHROMA_USE_HTTP=true
# CHROMA_HOST=chromadb        # service name in docker-compose / Render internal URL
# CHROMA_PORT=8000

CHROMA_COLLECTION_NAME=asktube_videos

# ── LangSmith (optional — for tracing) ───────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=AskTube-AI
LANGSMITH_EVAL_PROJECT=AskTube-AI-Evals
LANGSMITH_LATENCY_BUDGET_MS=8000

# ── RAG Evaluation ────────────────────────────────────────────────────────────
HALLUCINATION_RISK_THRESHOLD=0.35
RAG_EVALUATOR_MODE=heuristic

# ── LangChain ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=AskTube-AI
